{
  "name": "llamacpp-launcher",
  "version": "1.0.23",
  "description": "Modern terminal UI launcher for llama.cpp server",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "files": [
    "dist/**/*.js",
    "config.default.json",
    "presets.json"
  ],
  "bin": {
    "llamacpp-launcher": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build:app": "tsc && node scripts/ensure-shebang.cjs",
    "build": "node scripts/bump-version.cjs && npm run build:app",
    "pack": "node scripts/bump-version.cjs && npm run build:app && npm pack --ignore-scripts",
    "prepack": "node scripts/bump-version.cjs",
    "postpack": "node scripts/rename-packed-tarball.cjs",
    "prepare": "npm run build:app",
    "start": "node dist/index.js",
    "test": "npm run build:app && node --test test/*.test.mjs"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "figures": "^6.1.0",
    "gradient-string": "^3.0.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
